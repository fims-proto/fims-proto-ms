					"listen": "prerequest",
					"script": {
						"exec": [
							"const voucherIds = pm.collectionVariables.get(\"voucher_ids\")",
							"const index = Number(pm.collectionVariables.get(\"voucher_index\")) || 0",
							"",
							"pm.collectionVariables.set(\"current_voucher_id\", voucherIds[index])",
							"pm.collectionVariables.set(\"voucher_index\", index + 1)"
						],
