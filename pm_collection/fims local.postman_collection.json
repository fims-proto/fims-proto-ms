			"name": "sob 1 > all ledgers",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Ledgers exists (count more than 0)\", function () {",
							"    pm.expect(pm.response.json().content.length).to.gt(0);",
							"});",
							"",
							"pm.test(\"Ledgers have right balance\", function () {",
							"    tobeTested = {",
							"        \"1001\": {",
							"            tested: false,",
							"            expectedDebit: \"101\",",
							"            expectedCredit: \"200\",",
							"            expectedBalance: \"-99\"",
							"        },",
							"        \"1002\": {",
							"            tested: false,",
							"            expectedDebit: \"400\",",
							"            expectedCredit: \"401\",",
							"            expectedBalance: \"-1\"",
							"        },",
							"        \"1002001\": {",
							"            tested: false,",
							"            expectedDebit: \"400\",",
							"            expectedCredit: \"300\",",
							"            expectedBalance: \"100\"",
							"        },",
							"        \"1002002\": {",
							"            tested: false,",
							"            expectedDebit: \"0\",",
							"            expectedCredit: \"101\",",
							"            expectedBalance: \"-101\"",
							"        },",
							"        \"1122\": {",
							"            tested: false,",
							"            expectedDebit: \"0\",",
							"            expectedCredit: \"400\",",
							"            expectedBalance: \"-400\"",
							"        },",
							"        \"6602\": {",
							"            tested: false,",
							"            expectedDebit: \"500\",",
							"            expectedCredit: \"0\",",
							"            expectedBalance: \"500\"",
							"        },",
							"        \"6602001\": {",
							"            tested: false,",
							"            expectedDebit: \"500\",",
							"            expectedCredit: \"0\",",
							"            expectedBalance: \"500\"",
							"        }",
							"    }",
							"",
							"    ls = pm.response.json().content;",
							"",
							"    for(let i = 0; i < ls.length ; i++) {",
							"        const accountNumber = ls[i].account.accountNumber;",
							"        if (tobeTested.hasOwnProperty(accountNumber)) {",
							"            tobeTested[accountNumber].tested = true;",
							"            tobeTested[accountNumber].debit = ls[i].periodDebit;",
							"            tobeTested[accountNumber].credit = ls[i].periodCredit;",
							"            tobeTested[accountNumber].balance = ls[i].endingBalance;",
							"        }",
							"    }",
							"",
							"    for (let key in tobeTested) {",
							"        pm.expect(tobeTested[key].tested).to.be.true;",
							"        pm.expect(tobeTested[key].expectedDebit).to.be.eq(tobeTested[key].debit);",
							"        pm.expect(tobeTested[key].expectedCredit).to.be.eq(tobeTested[key].credit);",
							"        pm.expect(tobeTested[key].expectedBalance).to.be.eq(tobeTested[key].balance);",
							"    }",
							"",
							"    console.log(tobeTested);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
