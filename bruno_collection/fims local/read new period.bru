meta {
  name: read new period
  type: http
  seq: 23
}

get {
  url: {{base_path}}/sob/{{sob}}/periods/current
  body: none
  auth: none
}

tests {
  test("Read current period 200", function () {
      expect(res.getStatus()).to.equal(200);
  })

  bru.setVar("current_period_id", res.body.id)
  bru.setVar("current_period", `${res.body.fiscalYear}-${res.body.periodNumber}..padEnd(2, '0')`)
}
