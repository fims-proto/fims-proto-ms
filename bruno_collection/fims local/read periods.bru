meta {
  name: read periods
  type: http
  seq: 8
}

get {
  url: {{base_path}}/sob/{{sob}}/periods
  body: none
  auth: none
}

tests {
  test("Read periods 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  const current = res.body.find(p => p.isCurrent)
  
  bru.setVar("current_period_id", current.id)
  bru.setVar("current_period", `${current.fiscalYear}-${current.periodNumber}..padEnd(2, '0')`)
}
