meta {
  name: read ledgers
  type: http
  seq: 21
}

get {
  url: {{base_path}}/sob/{{sob}}/period/{{current_period}}/ledgers?$size=999
  body: none
  auth: none
}

params:query {
  $size: 999
}

tests {
  test("Ledgers exists (count more than 0)", function () {
      expect(res.getBody().content.length).to.gt(0);
  });
  
  test("Ledgers have right balance", function () {
      const tobeTested = {
          "1001": {
              "tested": false,
              "expectedDebit": "100000",
              "expectedCredit": "1600",
              "expectedAmount": "98400"
          },
          "1002": {
              "tested": false,
              "expectedDebit": "500000",
              "expectedCredit": "215000",
              "expectedAmount": "285000"
          },
          "100201": {
              "tested": false,
              "expectedDebit": "500000",
              "expectedCredit": "215000",
              "expectedAmount": "285000"
          },
          "1601": {
              "tested": false,
              "expectedDebit": "18500",
              "expectedCredit": "0",
              "expectedAmount": "18500"
          },
          "160101": {
              "tested": false,
              "expectedDebit": "18500",
              "expectedCredit": "0",
              "expectedAmount": "18500"
          },
          "1701": {
              "tested": false,
              "expectedDebit": "36000",
              "expectedCredit": "0",
              "expectedAmount": "36000"
          },
          "170101": {
              "tested": false,
              "expectedDebit": "36000",
              "expectedCredit": "0",
              "expectedAmount": "36000"
          },
          "1702": {
              "tested": false,
              "expectedDebit": "0",
              "expectedCredit": "1000",
              "expectedAmount": "-1000"
          },
          "1801": {
              "tested": false,
              "expectedDebit": "60000",
              "expectedCredit": "2500",
              "expectedAmount": "57500"
          },
          "180101": {
              "tested": false,
              "expectedDebit": "60000",
              "expectedCredit": "2500",
              "expectedAmount": "57500"
          },
          "2211": {
              "tested": false,
              "expectedDebit": "0",
              "expectedCredit": "10000",
              "expectedAmount": "-10000"
          },
          "221101": {
              "tested": false,
              "expectedDebit": "0",
              "expectedCredit": "10000",
              "expectedAmount": "-10000"
          },
          "3001": {
              "tested": false,
              "expectedDebit": "0",
              "expectedCredit": "500000",
              "expectedAmount": "-500000"
          },
          "300101": {
              "tested": false,
              "expectedDebit": "0",
              "expectedCredit": "300000",
              "expectedAmount": "-300000"
          },
          "300102": {
              "tested": false,
              "expectedDebit": "0",
              "expectedCredit": "200000",
              "expectedAmount": "-200000"
          },
          "3103": {
              "tested": false,
              "expectedDebit": "15600",
              "expectedCredit": "0",
              "expectedAmount": "15600"
          },
          "5602": {
              "tested": false,
              "expectedDebit": "15600",
              "expectedCredit": "15600",
              "expectedAmount": "0"
          },
          "560201": {
              "tested": false,
              "expectedDebit": "1600",
              "expectedCredit": "1600",
              "expectedAmount": "0"
          },
          "560202": {
              "tested": false,
              "expectedDebit": "500",
              "expectedCredit": "500",
              "expectedAmount": "0"
          },
          "560203": {
              "tested": false,
              "expectedDebit": "10000",
              "expectedCredit": "10000",
              "expectedAmount": "0"
          },
          "560204": {
              "tested": false,
              "expectedDebit": "1000",
              "expectedCredit": "1000",
              "expectedAmount": "0"
          },
          "560205": {
              "tested": false,
              "expectedDebit": "2500",
              "expectedCredit": "2500",
              "expectedAmount": "0"
          }
      }

      const ls = res.getBody().content;

      for (let i = 0; i < ls.length; i++) {
          const accountNumber = ls[i].account.accountNumber;
          if (tobeTested.hasOwnProperty(accountNumber)) {
              tobeTested[accountNumber].tested = true;
              tobeTested[accountNumber].debit = ls[i].periodDebit;
              tobeTested[accountNumber].credit = ls[i].periodCredit;
              tobeTested[accountNumber].amount = ls[i].endingAmount;
          }
      }

      for (let key in tobeTested) {
          expect(tobeTested[key].tested, `${key} not tested`).to.be.true;
          expect(tobeTested[key].expectedDebit, `${key} wrong period debit`).to.be.eq(tobeTested[key].debit);
          expect(tobeTested[key].expectedCredit, `${key} wrong period credit`).to.be.eq(tobeTested[key].credit);
          expect(tobeTested[key].expectedAmount, `${key} wrong ending amount`).to.be.eq(tobeTested[key].amount);
      }
  });
}
